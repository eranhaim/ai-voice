# Telegram bot token (required) — get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ElevenLabs (required) — get free key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa
ELEVENLABS_MODEL=eleven_v3

# MongoDB Atlas (required)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/voice_bot
MONGO_DB=voice_bot

# OpenAI (required for voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Admin dashboard password
ADMIN_PASSWORD=changeme

# AWS S3 (for voice sample storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=us-east-1
