# Telegram bot token (required) — get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ElevenLabs (required) — get free key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID — the female voice to convert to
# Default: Rachel (21m00Tcm4TlvDq8ikWAM) — young, warm female
# Other options:
#   Bella  (EXAVITQu4vr4xnSDxMaL) — soft, warm
#   Alice  (Xb7hH8MSUJpSbSDYk0k2) — clear, British
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Model — multilingual preserves Hebrew
ELEVENLABS_MODEL=eleven_multilingual_sts_v2
